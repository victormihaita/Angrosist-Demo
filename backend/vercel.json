{
  "functions": {
    "api/health/index.go": { "runtime": "vercel-go@3.x" },
    "api/chat/index.go":   { "runtime": "vercel-go@3.x" },
    "api/leads/index.go":  { "runtime": "vercel-go@3.x" },
    "api/leads/detail/index.go": { "runtime": "vercel-go@3.x" }
  },
  "routes": [
    { "src": "/api/health",        "dest": "/api/health/index.go" },
    { "src": "/api/chat",          "dest": "/api/chat/index.go" },
    { "src": "/api/leads/([^/]+)", "dest": "/api/leads/detail/index.go" },
    { "src": "/api/leads",         "dest": "/api/leads/index.go" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
